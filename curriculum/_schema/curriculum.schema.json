{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "COSY Curriculum",
  "type": "object",
  "required": ["language", "course_type", "level", "units"],
  "properties": {
    "language": { "type": "string" },
    "course_type": { "type": "string", "enum": ["general","spoken","exam","travelling","professional","relocation"] },
    "level": { "type": "string", "enum": ["A1","A2","B1","B2","C1","C2"] },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit", "title", "lessons"],
        "properties": {
          "unit": { "type": "integer" },
          "title": { "type": "string", "description": "Unit title in the target language" },
          "lessons": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["lesson", "title"],
              "properties": {
                "lesson": { "type": "integer" },
                "type": { "type": "string", "enum": ["vocab", "grammar", "gv", "spoken", "srev", "exam"] },
                "title": { "type": "string" },
                "recycled": { "type": ["string", "null"] },
                "duration_minutes": { "type": "integer" },
                "grammar": { "type": "array", "items": { "type": "string" } },
                "vocabulary": { "type": "array", "items": { "type": "string" } },
                "practice_types": { "type": "array", "items": { "type": "string" } },
                "speaking_percent": { "type": "integer" },
                "teacher_notes": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
