const container = document.getElementById("curriculum");
let openCount = 0;

units.forEach(unit => {
  const el = document.createElement("div");
  el.className = "unit";
  el.id = `unit-${unit.num}`;
  const tagHTML = unit.tags.map(t => `<span class="unit-tag t-vocab">${t}</span>`).join("");
  const lessonsHTML = unit.lessons.map((l, i) => {
    const t = TYPE[l.type];
    const recycledHTML = l.recycled ? `<div class="lesson-recycled">${l.recycled}</div>` : "";
    return `<div class="lesson">
      <div class="lesson-stripe stripe-${t.css}"></div>
      <div class="lesson-type-block">
        <span class="lesson-num">${i + 1}</span>
        <span class="lesson-type-pill t-${t.css}">${t.label}</span>
      </div>
      <div class="lesson-content">
        <div class="lesson-title">${l.title}</div>
        <div class="lesson-desc">${l.desc}</div>
        ${recycledHTML}
      </div>
    </div>`;
  }).join("");
  el.innerHTML = `
    <div class="unit-header" onclick="toggleUnit(${unit.num})">
      <div class="unit-num-block">
        <span class="unit-num-label">Unit</span>
        <span class="unit-num-value">${unit.num}</span>
      </div>
      <div class="unit-title-block">
        <div class="unit-emoji">${unit.emoji}</div>
        <div class="unit-title">${unit.title}</div>
        <div class="unit-tags">${tagHTML}</div>
      </div>
      <div class="unit-chevron">▼</div>
    </div>
    <div class="lessons">${lessonsHTML}</div>`;
  container.appendChild(el);
});

function toggleUnit(num) {
  const el = document.getElementById(`unit-${num}`);
  el.classList.toggle("open");
  openCount = document.querySelectorAll(".unit.open").length;
  document.getElementById("progress-label").textContent =
    `${openCount} of ${units.length} unit${openCount !== 1 ? "s" : ""} expanded`;
  document.getElementById("progress-fill").style.width =
    `${(openCount / units.length) * 100}%`;
}
toggleUnit(1);
