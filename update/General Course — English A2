.stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 0.75rem 1.25rem; min-width: 120px; }
.stat-val { font-family: 'DM Serif Display', serif; font-size: 26px; color: var(--a2-accent); line-height: 1; }
