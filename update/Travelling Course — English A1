.stripe-vocab { background: var(--c-vocab); } .stripe-grammar { background: var(--c-grammar); }
.stripe-gv { background: var(--c-gv); } .stripe-spoken { background: var(--c-spoken); }
.stripe-srev { background: var(--c-srev); } .stripe-exam { background: var(--c-exam); }
