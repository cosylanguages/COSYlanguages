<script>
const TYPE = {
  vocab:   { label: "Vocab",    css: "vocab" },
  grammar: { label: "Grammar",  css: "grammar" },
  gv:      { label: "Gram+Voc", css: "gv" },
  spoken:  { label: "Spoken",   css: "spoken" },
  srev:    { label: "Spk+Rev",  css: "srev" },
  exam:    { label: "Exam",     css: "exam" },
};

const units = [
  {
    num: 1, emoji: "👋", title: "Greetings & introductions",
    tags: ["to be (I/you)", "hello/goodbye", "names", "spelling"],
    lessons: [
      {
        type: "vocab",
        title: "Survival greetings & introducing yourself",
        desc: "Hello, hi, good morning/afternoon/evening, goodbye, bye, see you later. My name is… / I'm… Nice to meet you. Please, thank you, you're welcome, sorry, excuse me. The alphabet — spelling your name at reception. Numbers 1–10 (room numbers, floor numbers).",
        recycled: null
      },
      {
        type: "grammar",
        title: "To be — I am, you are (positive, negative, questions)",
        desc: "I am / I'm · You are / You're. Contractions. I am not / You are not. Questions: Are you…? Yes, I am. / No, I'm not. Travel contexts: Are you the taxi driver? I'm a tourist. I'm not from here.",
        recycled: null
      },
      {
        type: "spoken",
        title: "First contact — meeting people on arrival",
        desc: "Role-plays: arriving at a hotel and greeting the receptionist; meeting a fellow traveller on a plane; introducing yourself to a tour guide. Students spell their name, give their room number, and use polite phrases throughout.",
        recycled: "Greetings vocabulary + I am / Are you…? from lessons 1 & 2."
      },
      {
        type: "srev",
        title: "Spoken course lesson: Hello, who are you?",
        desc: "Spoken Course A1 Travelling lesson. Pure spontaneous introduction — no written support. Students greet, introduce themselves, spell their name, and exchange basic pleasantries as if at an airport or hotel check-in.",
        recycled: "Full active revision of Unit 1 vocabulary and grammar in a real travel context."
      },
      {
        type: "exam",
        title: "Unit 1 exam",
        desc: "Listening: identify greetings in a hotel dialogue. Reading: match names to spellings on a check-in form. Writing: fill in an arrival card (name, nationality). Speaking: greet the examiner as if arriving at a hotel — introduce yourself and spell your name.",
        recycled: "All Unit 1 content in a realistic travel scenario."
      }
    ]
  },
  {
    num: 2, emoji: "💶", title: "Numbers & money",
    tags: ["numbers 1–100", "how much is…?", "prices", "currency"],
    lessons: [
      {
        type: "vocab",
        title: "Numbers, prices & currency",
        desc: "Numbers 1–100. Currency words: euro, pound, dollar, cent, pence. Price phrases: It costs…, It's…euros, That's…pounds. Cheap, expensive, free, discount, change (money), cash, card, pay, receipt, total. How much? How many?",
        recycled: "Numbers 1–10 from Unit 1 (room numbers) now extended to 100 — covering all prices, floor numbers, seat numbers."
      },
      {
        type: "grammar",
        title: "How much is…? / It costs… — price questions & answers",
        desc: "How much is the ticket? It's €15. How much are the rooms? They are €80 per night. I'd like to pay by card. Do you have change? That's too expensive. Have you got anything cheaper? Numbers in context: floor 3, seat 24, gate 11.",
        recycled: "To be (Unit 1): It is / They are — now used for prices. Are you…? adapted to Is it…? How much is it?"
      },
      {
        type: "spoken",
        title: "Paying and handling money while travelling",
        desc: "Role-plays: buying a ticket at a transport counter; paying for a souvenir; asking the price of a meal. Students use numbers confidently, ask for change, and handle card vs. cash scenarios. Teacher introduces surprise prices to test listening.",
        recycled: "↻ Greetings (Unit 1) open every transaction — Excuse me, hello, thank you. To be (Unit 1) for prices. Numbers 1–10 (Unit 1) now extended to all travel prices."
      },
      {
        type: "srev",
        title: "Spoken course lesson: At the market",
        desc: "Spoken Course A1 Travelling lesson. Students buy items at an imaginary market — negotiating prices, asking for totals, paying and receiving change. The teacher plays a vendor who varies prices and asks follow-up questions.",
        recycled: "Units 1–2: greetings + numbers + to be + price questions all simultaneously active."
      },
      {
        type: "exam",
        title: "Unit 2 exam",
        desc: "Listening: hear prices in a dialogue and write them down. Reading: a simple menu or price list — answer how much questions. Writing: fill in a payment form (amounts, totals). Speaking: buy three items from the examiner using numbers and price phrases.",
        recycled: "Units 1–2 fully integrated: the buying scenario demands greetings, to be, and numbers all at once."
      }
    ]
  },
  {
    num: 3, emoji: "✈️", title: "At the airport",
    tags: ["airport vocabulary", "where is…?", "directions basics", "to be (he/she)"],
    lessons: [
      {
        type: "vocab",
        title: "Airport vocabulary — check-in to boarding",
        desc: "Passport, boarding pass, check-in, luggage, suitcase, bag, security, gate, flight, departure, arrival, delay, terminal, trolley, customs, immigration, queue, sign. Signs you'll see: Arrivals, Departures, Exit, Information, Toilets, Baggage claim.",
        recycled: "Numbers (Unit 2): gate 14, terminal 2, flight BA204. Greetings (Unit 1): at check-in and information desks."
      },
      {
        type: "grammar",
        title: "Where is…? / Where are…? + to be he/she/it",
        desc: "Where is the gate? It's on the left. Where are the toilets? They're downstairs. He is at the check-in desk. She is not here yet. Is the flight delayed? Yes, it is. Basic prepositions: on the left/right, upstairs/downstairs, straight ahead, next to, opposite.",
        recycled: "To be I/you (Units 1–2) extended to he/she/it/they. Numbers (Unit 2): It's gate 22. Greetings (Unit 1): Excuse me, where is…?"
      },
      {
        type: "spoken",
        title: "Navigating the airport",
        desc: "Role-plays: asking airport staff where things are; checking in and handing over a passport; asking about a delayed flight. Students use where is/are, basic directions, and polite greetings together. Teacher creates a flight delay scenario requiring problem phrases.",
        recycled: "↻ Greetings (Unit 1): Excuse me, hello, thank you. Numbers (Unit 2): flight number, gate, time. To be (Units 1–2): Is the gate open? They are at terminal 3. Prices (Unit 2): excess baggage fees."
      },
      {
        type: "srev",
        title: "Spoken course lesson: Asking for help",
        desc: "Spoken Course A1 Travelling lesson. A pure help-seeking conversation in an airport setting. Students must locate gates, ask about their flight, find facilities — all without written prompts. Teacher introduces unexpected problems: a wrong gate, a missing bag.",
        recycled: "Units 1–3: greetings, numbers, to be (all forms), where is/are, airport vocabulary in free conversation."
      },
      {
        type: "exam",
        title: "Unit 3 exam",
        desc: "Listening: airport announcements — identify gate, flight number, and instructions. Reading: an airport sign map — answer where questions. Writing: complete a check-in form and write 3 sentences about your flight. Speaking: navigate an airport scenario with the examiner — find your gate, report a lost bag.",
        recycled: "Units 1–3: numbers + to be + where is/are + airport vocabulary all tested in one scenario."
      }
    ]
  },
  {
    num: 4, emoji: "🚌", title: "Getting around — Transport & directions",
    tags: ["imperatives", "transport vocabulary", "directions", "take/get on/off"],
    lessons: [
      {
        type: "vocab",
        title: "Transport vocabulary & direction words",
        desc: "Bus, metro/underground, taxi, tram, train, ferry, bike, car, on foot. Stop, station, platform, ticket, single, return, timetable, line, route. Direction words: left, right, straight on/ahead, turn, cross, go past, at the traffic lights, at the corner, the first/second street.",
        recycled: "Numbers (Unit 2): platform 3, line 4, bus 72. Prices (Unit 2): ticket prices, single vs return. Airport vocabulary (Unit 3): train to terminal 2."
      },
      {
        type: "grammar",
        title: "Imperatives & movement verbs — giving and following directions",
        desc: "Take the number 10 bus. Get on at Central Station. Get off at the third stop. Turn left. Go straight on. Don't turn right. Walk for five minutes. Cross the bridge. Positive and negative imperatives. How do I get to…? / How long does it take? It takes about 20 minutes.",
        recycled: "Numbers (Unit 2): three stops, 20 minutes, platform 5. To be (Units 1–3): It is on the left. They are at stop 4. Where is…? (Unit 3) now extended with imperative answers."
      },
      {
        type: "spoken",
        title: "Getting from A to B",
        desc: "Role-plays: asking for directions in the street; buying a transport ticket; asking how to get to the hotel from the station. Students give and follow directions on a simple map. Teacher introduces a missed stop scenario requiring problem-solving language.",
        recycled: "↻ Greetings (Unit 1): Excuse me, could you help me? Numbers (Unit 2): stop numbers, prices. Airport vocabulary (Unit 3): linked to train/bus from airport. To be (Units 1–3): Is this the right bus? Are you going to the centre?"
      },
      {
        type: "srev",
        title: "Spoken course lesson: In a taxi",
        desc: "Spoken Course A1 Travelling lesson. A full taxi journey: hailing the cab, giving the destination, asking how long, understanding the price, paying and tipping. Teacher plays an awkward driver who asks questions back.",
        recycled: "Units 1–4 fully active: greetings, numbers/prices, where is/are, transport vocabulary, imperatives — all needed in a taxi ride."
      },
      {
        type: "exam",
        title: "Unit 4 exam",
        desc: "Listening: follow directions and identify the destination on a map. Reading: a transport timetable — answer time and platform questions. Writing: write directions from the station to a hotel (6–8 sentences using imperatives). Speaking: give directions to the examiner using a map, then buy a ticket at a counter.",
        recycled: "Units 1–4: full integration — the exam combines all survival transport skills."
      }
    ]
  },
  {
    num: 5, emoji: "🏨", title: "Accommodation — Hotels & checking in",
    tags: ["I'd like / I need", "hotel vocabulary", "requests", "there is/are"],
    lessons: [
      {
        type: "vocab",
        title: "Hotel vocabulary — rooms, facilities & problems",
        desc: "Room: single, double, twin, suite. Facilities: bathroom, shower, bath, balcony, WiFi, air conditioning, heating, safe, minibar, room service, reception, lift/elevator, stairs, key card. Check in/out, booking, reservation, full board, half board, bed and breakfast. Problems: broken, not working, noisy, dirty, too hot/cold.",
        recycled: "Numbers (Unit 2): room number, floor, price per night. Greetings (Unit 1): at reception. To be (Units 1–3): Is the room ready? Where is the lift? (Unit 3)."
      },
      {
        type: "grammar",
        title: "I'd like / I need / Can I have…? — polite requests + there is/are",
        desc: "I'd like a double room, please. I need a towel. Can I have the key? Could I have a wake-up call at 7? There is a swimming pool. There isn't a gym. Is there a restaurant? Are there any rooms available? There are two beds. Comparing there is (Unit 3's It is) with the new structure.",
        recycled: "There is/are introduced — directly connected to Where is/are (Unit 3) and prices (Unit 2): There is a room for €90. Numbers (Unit 2): There are 3 floors. To be (Units 1–3) as the core of there is/are."
      },
      {
        type: "spoken",
        title: "Checking in and dealing with hotel issues",
        desc: "Role-plays: checking into a hotel (booking, room type, price, facilities); reporting a problem (the WiFi isn't working, there's no hot water); asking for information about the hotel. Teacher introduces an overbooking crisis requiring negotiation.",
        recycled: "↻ Greetings (Unit 1): Hello, good evening, thank you. Numbers/prices (Unit 2): room price, floor, nights. Directions (Unit 4): where is the restaurant? Where are the stairs? Transport (Unit 4): Is there a shuttle to the airport?"
      },
      {
        type: "srev",
        title: "Spoken course lesson: Hotel problems",
        desc: "Spoken Course A1 Travelling lesson. Students handle a series of hotel problems: wrong room type, broken shower, noisy neighbours, missing booking. Teacher escalates each issue to demand more language. Students must stay polite and persistent.",
        recycled: "Units 1–5: all vocabulary and grammar in a high-pressure real-world scenario."
      },
      {
        type: "exam",
        title: "Unit 5 exam",
        desc: "Listening: a hotel check-in dialogue — identify room type, floor, price and one problem. Reading: a hotel booking confirmation — answer comprehension questions. Writing: write an email requesting a room (I'd like, there is/are, numbers). Speaking: check in to the hotel with the examiner, then report two problems.",
        recycled: "Units 1–5: the check-in exam naturally demands greetings, numbers, where is, transport (arrival), and hotel vocabulary all at once."
      }
    ]
  },
  {
    num: 6, emoji: "🍽️", title: "Eating & drinking — Restaurants & cafés",
    tags: ["ordering", "can I have…?", "food vocabulary", "preferences"],
    lessons: [
      {
        type: "vocab",
        title: "Restaurant & food vocabulary",
        desc: "Menu, starter, main course, dessert, drink. Food: meat, fish, chicken, vegetarian, vegan, pasta, rice, bread, salad, soup, cheese. Drinks: water (still/sparkling), juice, coffee, tea, wine, beer. Allergens: nuts, dairy, gluten. Phrases: I'm allergic to…, without…, on the side, well done/medium/rare (steak). Bill, tip, service charge.",
        recycled: "Numbers/prices (Unit 2): menu prices, bill total. Greetings (Unit 1): at the restaurant entrance. I'd like (Unit 5) directly applied to ordering food."
      },
      {
        type: "grammar",
        title: "Can I have…? / I'll have… / What do you recommend? — ordering structures",
        desc: "Can I have the chicken, please? I'll have the pasta. What do you recommend? Is there a vegetarian option? I'd like a table for two. For me, the fish. And to drink? I'll have a glass of water. Excuse me, the bill please. Present simple questions: Do you have…? Does it come with…?",
        recycled: "I'd like (Unit 5) now joined by Can I have and I'll have for variety. Numbers (Unit 2): table for 2, two glasses, €35 for the bill. There is/are (Unit 5): Is there a vegetarian option? Are there any specials today?"
      },
      {
        type: "spoken",
        title: "Ordering a full meal",
        desc: "Role-plays: arriving at a restaurant and being seated; reading the menu and ordering a full meal; asking about ingredients; paying the bill and leaving a tip. Teacher plays a waiter who asks follow-up questions and introduces daily specials. Students handle a dietary restriction scenario.",
        recycled: "↻ Greetings (Unit 1): Good evening, thank you, goodbye. Numbers/prices (Unit 2): menu prices, total bill. I'd like (Unit 5): I'd like a table. Where is the toilet? (Unit 3/4). Transport (Unit 4): linking dinner to getting home after."
      },
      {
