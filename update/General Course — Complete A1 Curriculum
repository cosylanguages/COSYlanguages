<script>
function showUnit(idx) {
  document.querySelectorAll('.unit-block').forEach((b,i) => b.classList.toggle('active', i===idx));
  document.querySelectorAll('.unit-nav').forEach((n,i) => n.classList.toggle('active', i===idx));
  window.scrollTo({top:0, behavior:'smooth'});
}
function tog(header) {
  const lesson = header.parentElement;
  const wasOpen = lesson.classList.contains('open');
  header.closest('.lessons').querySelectorAll('.lesson').forEach(l => l.classList.remove('open'));
  if (!wasOpen) lesson.classList.add('open');
}
document.addEventListener('DOMContentLoaded', () => {
  const first = document.querySelector('.unit-block.active .lesson');
  if (first) first.classList.add('open');
});
</script>
