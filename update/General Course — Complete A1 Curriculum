<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>COSYlanguages — General Course A1 Complete Curriculum</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--cream:#F7F4EE;--ink:#1A1714;--ink-soft:#4A453F;--ink-muted:#8C8680;--border:#DDD9D2;
--green:#3E6B1A;--green-bg:#EAF3DE;--green-border:#B8D98A;
--blue:#1A4E8C;--blue-bg:#E4EEF9;--blue-border:#9BBDE0;
--purple:#3E2E9E;--purple-bg:#ECEAF9;--purple-border:#B8B0EA;
--amber:#8C5A10;--amber-bg:#FAF0DC;--amber-border:#E8C87A;
--red:#8C2A10;--red-bg:#FAE8E4;--red-border:#E8A090;
--r:10px;--rs:6px;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--cream);color:var(--ink);font-family:'DM Sans',sans-serif;line-height:1.6;}
/* HEADER */
.site-header{background:var(--ink);color:var(--cream);padding:24px 36px;display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;}
.site-header h1{font-family:'DM Serif Display',serif;font-size:26px;letter-spacing:-0.02em;}
.site-header h1 em{font-style:italic;opacity:0.55;}
.site-header .meta{font-size:12px;opacity:0.5;margin-top:4px;font-weight:300;}
.badge-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px;}
.badge{font-size:10px;font-weight:500;padding:2px 9px;border-radius:20px;border:1px solid rgba(255,255,255,0.2);opacity:0.75;letter-spacing:0.04em;}
/* LEGEND */
.legend-bar{display:flex;gap:18px;flex-wrap:wrap;padding:12px 36px;background:#F0ECE4;border-bottom:1px solid var(--border);}
.li{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--ink-soft);font-weight:500;}
.li-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
/* LAYOUT */
.layout{display:flex;min-height:calc(100vh - 110px);}
/* SIDEBAR */
.sidebar{width:260px;flex-shrink:0;background:#EFECE5;border-right:1px solid var(--border);padding:20px 0;position:sticky;top:0;height:100vh;overflow-y:auto;}
.sb-part{padding:8px 18px 4px;font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-muted);margin-top:8px;}
.sb-part:first-child{margin-top:0;}
.sb-divider{height:1px;background:var(--border);margin:4px 0;}
.unit-nav{padding:6px 18px;cursor:pointer;border-left:3px solid transparent;transition:all .15s;display:block;}
.unit-nav:hover{background:rgba(0,0,0,0.04);}
.unit-nav.active{border-left-color:var(--ink);background:rgba(0,0,0,0.06);}
.unit-nav .un{font-size:9px;color:var(--ink-muted);font-weight:600;letter-spacing:0.04em;}
.unit-nav .ut{font-size:12px;color:var(--ink);font-weight:500;line-height:1.3;margin-top:1px;}
/* CONTENT */
.content{flex:1;padding:28px 36px;max-width:940px;}
.unit-block{display:none;}.unit-block.active{display:block;}
/* UNIT HEADER */
.unit-header{margin-bottom:24px;padding-bottom:18px;border-bottom:1px solid var(--border);}
.unit-num{font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:5px;}
.unit-title{font-family:'DM Serif Display',serif;font-size:30px;letter-spacing:-0.02em;line-height:1.1;margin-bottom:10px;}
.unit-desc{font-size:13px;color:var(--ink-soft);line-height:1.6;max-width:640px;margin-bottom:12px;}
.prog-wrap{height:3px;background:var(--border);border-radius:99px;margin-top:12px;overflow:hidden;}
.prog-fill{height:100%;background:var(--ink);border-radius:99px;}
/* PART BADGE */
.part-badge{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;margin-bottom:14px;letter-spacing:0.04em;}
.part1-badge{background:#E8F4D8;color:#3E6B1A;border:1px solid #B8D98A;}
.part2-badge{background:#E4EEF9;color:#1A4E8C;border:1px solid #9BBDE0;}
/* RECYCLE BAR */
.recycle-bar{display:flex;align-items:flex-start;gap:8px;background:#F0ECE4;border:1px solid var(--border);border-radius:var(--rs);padding:9px 13px;font-size:11px;color:var(--ink-soft);line-height:1.5;margin-bottom:20px;}
/* LESSONS */
.lessons{display:flex;flex-direction:column;gap:12px;}
.lesson{border-radius:var(--r);border:1px solid var(--border);overflow:hidden;}
.lesson-header{display:flex;align-items:center;gap:10px;padding:12px 16px;cursor:pointer;user-select:none;transition:opacity .15s;}
.lesson-header:hover{opacity:0.82;}
.lesson-num{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;}
.lesson-title{font-size:13px;font-weight:600;flex:1;}
.lesson-sub{font-size:11px;opacity:0.65;margin-top:1px;}
.lesson-arrow{font-size:10px;opacity:0.4;transition:transform .2s;flex-shrink:0;}
.lesson.open .lesson-arrow{transform:rotate(180deg);}
.lesson-body{display:none;padding:0 16px 18px;}
.lesson.open .lesson-body{display:block;}
/* LESSON SECTIONS */
.ls{margin-bottom:16px;}.ls:last-child{margin-bottom:0;}
.ls-title{font-size:10px;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;margin-bottom:7px;padding-bottom:4px;border-bottom:1px solid;}
/* VOCAB */
.vgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:5px;}
.vi{background:white;border:1px solid var(--green-border);border-radius:var(--rs);padding:6px 9px;}
.vw{font-size:11px;font-weight:600;color:var(--green);}
.vd{font-size:10px;color:var(--ink-muted);margin-top:1px;}
.vrrow{display:flex;flex-wrap:wrap;gap:4px;margin-top:3px;}
.vr{font-size:10px;background:#F4F2EE;border:1px solid var(--border);border-radius:20px;padding:2px 8px;color:var(--ink-muted);}
/* GRAMMAR */
.gbox{background:white;border:1px solid var(--blue-border);border-radius:var(--rs);padding:11px 13px;margin-bottom:7px;}
.gr{font-size:12px;font-weight:700;color:var(--blue);margin-bottom:3px;}
.ge{font-size:11px;color:var(--ink-soft);margin-bottom:7px;line-height:1.5;}
.ex{font-size:11px;background:var(--blue-bg);border-radius:4px;padding:3px 7px;color:var(--ink);font-style:italic;margin-bottom:2px;}
/* ACTIVITIES */
.act{background:white;border:1px solid var(--purple-border);border-radius:var(--rs);padding:9px 11px;margin-bottom:5px;}
.an{font-size:11px;font-weight:700;color:var(--purple);margin-bottom:2px;}
.ad{font-size:11px;color:var(--ink-soft);line-height:1.5;}
.ap{font-size:10px;color:var(--purple);font-style:italic;margin-top:4px;border-left:2px solid var(--purple-border);padding-left:7px;line-height:1.5;}
/* SPOKEN */
.sbox{background:var(--amber-bg);border:1px solid var(--amber-border);border-radius:var(--rs);padding:11px 13px;}
.sc{font-size:10px;font-weight:700;color:var(--amber);letter-spacing:0.05em;margin-bottom:3px;}
.st{font-size:12px;font-weight:700;color:#5A3800;margin-bottom:7px;}
.sstep{display:flex;gap:7px;font-size:11px;color:var(--ink-soft);margin-bottom:4px;line-height:1.5;}
.sn{width:17px;height:17px;border-radius:50%;background:var(--amber);color:white;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
.rnote{margin-top:9px;padding:7px 9px;background:rgba(140,90,16,0.08);border-radius:var(--rs);font-size:10px;color:var(--amber);line-height:1.5;}
/* EXAM */
.epart{background:white;border:1px solid var(--red-border);border-radius:var(--rs);padding:9px 11px;margin-bottom:5px;}
.el{font-size:10px;font-weight:700;color:var(--red);letter-spacing:0.04em;margin-bottom:3px;}
.ed{font-size:11px;color:var(--ink-soft);line-height:1.5;}
.ei{font-size:10px;color:var(--ink-muted);padding-left:11px;position:relative;margin-top:2px;line-height:1.4;}
.ei::before{content:"–";position:absolute;left:0;}
/* COLOURS per lesson type */
.L1{background:var(--green-bg);}.L1 .lesson-header{background:var(--green-bg);}.L1 .lesson-num{background:var(--green);color:white;}.L1 .lesson-title{color:var(--green);}.L1 .ls-title{color:var(--green);border-color:var(--green-border);}
.L2{background:var(--blue-bg);}.L2 .lesson-header{background:var(--blue-bg);}.L2 .lesson-num{background:var(--blue);color:white;}.L2 .lesson-title{color:var(--blue);}.L2 .ls-title{color:var(--blue);border-color:var(--blue-border);}
.L3{background:var(--purple-bg);}.L3 .lesson-header{background:var(--purple-bg);}.L3 .lesson-num{background:var(--purple);color:white;}.L3 .lesson-title{color:var(--purple);}.L3 .ls-title{color:var(--purple);border-color:var(--purple-border);}
.L4{background:var(--amber-bg);}.L4 .lesson-header{background:var(--amber-bg);}.L4 .lesson-num{background:var(--amber);color:white;}.L4 .lesson-title{color:var(--amber);}.L4 .ls-title{color:var(--amber);border-color:var(--amber-border);}
.L5{background:var(--red-bg);}.L5 .lesson-header{background:var(--red-bg);}.L5 .lesson-num{background:var(--red);color:white;}.L5 .lesson-title{color:var(--red);}.L5 .ls-title{color:var(--red);border-color:var(--red-border);}
/* NAV */
.nav-buttons{display:flex;gap:8px;margin-top:28px;padding-top:20px;border-top:1px solid var(--border);}
.nav-btn{padding:9px 18px;border-radius:var(--rs);font-size:12px;font-weight:500;cursor:pointer;border:1px solid var(--border);background:white;color:var(--ink);transition:all .15s;font-family:'DM Sans',sans-serif;}
.nav-btn:hover{background:var(--ink);color:var(--cream);border-color:var(--ink);}
.nav-btn.primary{background:var(--ink);color:var(--cream);border-color:var(--ink);}
.nav-btn:disabled{opacity:0.3;pointer-events:none;}
@media(max-width:680px){.sidebar{display:none;}.content{padding:16px;}}
</style>
</head>
