<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>A1 Curriculum — General Course (English) — COSYlanguages</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
/* ── Base ───────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:       #FAF8F4;
  --surface:  #FFFFFF;
  --border:   #E8E4DC;
  --border2:  #D0C9BE;
  --text:     #1C1A17;
  --muted:    #6B6560;
  --hint:     #A09890;

  --a1-accent: #1D7D5A;
  --a1-light:  #EAF5EF;
  --a1-mid:    #C0E3D0;

  --c-vocab:      #1A6B8A;
  --c-vocab-bg:   #E6F3F8;
  --c-grammar:    #5B3FA6;
  --c-grammar-bg: #EEE9FA;
  --c-gv:         #1D7D5A;
  --c-gv-bg:      #E6F5EE;
  --c-spoken:     #B85C00;
  --c-spoken-bg:  #FDF0E3;
  --c-srev:       #9C3030;
  --c-srev-bg:    #FAEAEA;
  --c-exam:       #3D3A35;
  --c-exam-bg:    #F1EFE8;

  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 16px;
  --shadow:    0 2px 12px rgba(0,0,0,0.07);
}

html { font-size: 16px; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  min-height: 100vh;
}

/* ── Layout ─────────────────────────────────────────────── */
.page-wrap { max-width: 900px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }

/* ── Header ─────────────────────────────────────────────── */
.page-header {
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 2px solid var(--border);
}
.breadcrumb {
  font-size: 13px; color: var(--hint); margin-bottom: 0.75rem;
  display: flex; align-items: center; gap: 6px;
}
.breadcrumb a { color: var(--hint); text-decoration: none; }
.breadcrumb a:hover { color: var(--a1-accent); }
.breadcrumb span { opacity: 0.5; }

.page-title {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(26px, 5vw, 38px);
  font-weight: 400;
  line-height: 1.2;
  color: var(--text);
  margin-bottom: 0.5rem;
}
.page-title em { color: var(--a1-accent); font-style: italic; }
.page-subtitle { font-size: 15px; color: var(--muted); max-width: 560px; }

.level-pill {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--a1-light); color: var(--a1-accent);
  border: 1px solid var(--a1-mid);
  border-radius: 20px; padding: 4px 14px;
  font-size: 13px; font-weight: 500;
  margin-top: 1rem;
}

/* ── Spiral info box ─────────────────────────────────────── */
.spiral-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 4px solid var(--a1-accent);
  border-radius: var(--radius-md);
  padding: 1rem 1.25rem;
  margin-bottom: 2rem;
  font-size: 14px;
  color: var(--muted);
}
.spiral-box strong { color: var(--text); }

/* ── Legend ─────────────────────────────────────────────── */
.legend {
  display: flex; flex-wrap: wrap; gap: 8px;
  margin-bottom: 2rem;
}
.legend-tag {
  font-size: 12px; font-weight: 500; padding: 4px 11px;
  border-radius: 20px; border: 1px solid transparent;
}

/* ── Unit cards ─────────────────────────────────────────── */
.unit {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  margin-bottom: 1rem;
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: box-shadow 0.2s;
}
.unit:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
.unit.open { border-color: var(--a1-mid); }

.unit-header {
  display: grid;
  grid-template-columns: 48px 1fr auto;
  align-items: center;
  gap: 0;
  padding: 0;
  cursor: pointer;
  user-select: none;
  background: var(--surface);
}
.unit-header:hover { background: #FDFBF8; }

.unit-num-block {
  background: var(--a1-light);
  border-right: 1px solid var(--a1-mid);
  align-self: stretch;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1rem 0;
  min-height: 64px;
}
.unit-num-label { font-size: 9px; font-weight: 600; color: var(--a1-accent); text-transform: uppercase; letter-spacing: 0.07em; }
.unit-num-value { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--a1-accent); line-height: 1; }

.unit-title-block {
  padding: 1rem 1.25rem;
}
.unit-emoji { font-size: 18px; margin-bottom: 2px; }
.unit-title {
  font-size: 16px; font-weight: 500; color: var(--text); line-height: 1.3;
}
.unit-tags {
  display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px;
}
.unit-tag {
  font-size: 10px; font-weight: 500; padding: 2px 8px;
  border-radius: 20px; border: 1px solid transparent;
}

.unit-chevron {
  padding: 1rem 1.25rem;
  color: var(--hint);
  font-size: 12px;
  transition: transform 0.25s;
  align-self: center;
}
.unit.open .unit-chevron { transform: rotate(180deg); }

/* ── Lessons ─────────────────────────────────────────────── */
.lessons { display: none; border-top: 1px solid var(--border); }
.unit.open .lessons { display: block; }

.lesson {
  display: grid;
  grid-template-columns: 4px 56px 1fr;
  border-bottom: 1px solid var(--border);
  min-height: 64px;
  transition: background 0.15s;
}
.lesson:last-child { border-bottom: none; }
.lesson:hover { background: #FDFBF8; }

.lesson-stripe { width: 4px; }

.lesson-type-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0.75rem 0.25rem;
  border-right: 1px solid var(--border);
}
.lesson-num { font-size: 10px; color: var(--hint); margin-bottom: 4px; }
.lesson-type-pill {
  font-size: 9px; font-weight: 600;
  padding: 3px 6px; border-radius: 4px;
  text-transform: uppercase; letter-spacing: 0.05em;
  text-align: center; line-height: 1.3;
  max-width: 52px;
}

.lesson-content {
  padding: 0.85rem 1rem 0.85rem 1rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4px;
}
.lesson-title {
  font-size: 14px; font-weight: 500; color: var(--text); line-height: 1.35;
}
.lesson-desc {
  font-size: 13px; color: var(--muted); line-height: 1.5;
}
.lesson-recycled {
  font-size: 12px; color: var(--a1-accent);
  margin-top: 4px;
  display: flex; align-items: flex-start; gap: 5px;
}
.lesson-recycled::before {
  content: "↻";
  font-size: 13px; flex-shrink: 0; margin-top: -1px;
}

/* ── Colour helpers ─────────────────────────────────────── */
.t-vocab    { background: var(--c-vocab-bg);   color: var(--c-vocab);   border-color: #B8D8E8; }
.t-grammar  { background: var(--c-grammar-bg); color: var(--c-grammar); border-color: #C9BBF0; }
.t-gv       { background: var(--c-gv-bg);      color: var(--c-gv);      border-color: #A8D8BC; }
.t-spoken   { background: var(--c-spoken-bg);  color: var(--c-spoken);  border-color: #F0C88A; }
.t-srev     { background: var(--c-srev-bg);    color: var(--c-srev);    border-color: #E8A8A8; }
.t-exam     { background: var(--c-exam-bg);    color: var(--c-exam);    border-color: #C8C4BC; }

.stripe-vocab    { background: var(--c-vocab);   }
.stripe-grammar  { background: var(--c-grammar); }
.stripe-gv       { background: var(--c-gv);      }
.stripe-spoken   { background: var(--c-spoken);  }
.stripe-srev     { background: var(--c-srev);    }
.stripe-exam     { background: var(--c-exam);    }

/* ── Progress bar ───────────────────────────────────────── */
.progress-bar {
  height: 5px;
  background: var(--border);
  border-radius: 3px;
  margin-bottom: 2rem;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--a1-accent), #5DCAA5);
  border-radius: 3px;
  width: 0%;
  transition: width 0.6s ease;
}
.progress-label {
  font-size: 12px; color: var(--hint);
  margin-bottom: 0.5rem;
}

/* ── Summary stats ──────────────────────────────────────── */
.stats {
  display: flex; flex-wrap: wrap; gap: 10px;
  margin-bottom: 2rem;
}
.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 0.75rem 1.25rem;
  min-width: 120px;
}
.stat-val { font-family: 'DM Serif Display', serif; font-size: 26px; color: var(--a1-accent); line-height: 1; }
.stat-lbl { font-size: 12px; color: var(--muted); margin-top: 2px; }

/* ── Responsive ─────────────────────────────────────────── */
@media (max-width: 600px) {
  .unit-header { grid-template-columns: 40px 1fr auto; }
  .unit-title { font-size: 14px; }
  .lesson { grid-template-columns: 3px 48px 1fr; }
  .stats { gap: 8px; }
  .stat-card { min-width: 100px; padding: 0.6rem 1rem; }
}
</style>
</head>
